{
   "info":{
      "name":"Travel API",
      "description":"Collection completa com Autenticação JWT, Me, Logout e Gestão de Pedidos de Viagem. Inclui Order Numbers dinâmicos e Timeline de Auditoria.",
      "schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
   },
   "item":[
      {
         "name":"0. Autenticação",
         "item":[
            {
               "name":"Login (Gerar JWT)",
               "event":[
                  {
                     "listen":"test",
                     "script":{
                        "exec":[
                           "const response = pm.response.json();",
                           "if (response.access_token) {",
                           "    pm.collectionVariables.set(\"jwt_token\", response.access_token);",
                           "    console.log(\"Token JWT salvo automaticamente!\");",
                           "}"
                        ],
                        "type":"text/javascript"
                     }
                  }
               ],
               "request":{
                  "method":"POST",
                  "header":[
                     
                  ],
                  "body":{
                     "mode":"raw",
                     "raw":"{\n    \"email\": \"admin@email.com\",\n    \"password\": \"password\"\n}",
                     "options":{
                        "raw":{
                           "language":"json"
                        }
                     }
                  },
                  "url":{
                     "raw":"{{base_url}}/api/v1/login",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "login"
                     ]
                  }
               }
            },
            {
               "name":"Me (Perfil do Usuário)",
               "request":{
                  "method":"GET",
                  "header":[
                     
                  ],
                  "url":{
                     "raw":"{{base_url}}/api/v1/me",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "me"
                     ]
                  },
                  "description":"Recupera os dados do usuário autenticado no formato UserResource, expondo DTO de permissões."
               }
            },
            {
               "name":"Logout",
               "request":{
                  "method":"POST",
                  "header":[
                     
                  ],
                  "url":{
                     "raw":"{{base_url}}/api/v1/logout",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "logout"
                     ]
                  },
                  "description":"Invalida o token JWT atual no servidor, bloqueando chamadas subsequentes com o mesmo token."
               }
            }
         ],
         "auth":{
            "type":"bearer",
            "bearer":[
               {
                  "key":"token",
                  "value":"{{jwt_token}}",
                  "type":"string"
               }
            ]
         }
      },
      {
         "name":"1. Pedidos de Viagem",
         "item":[
            {
               "name":"Admin Only",
               "item":[
                  {
                     "name":"Aprovar Pedido",
                     "request":{
                        "method":"PATCH",
                        "header":[
                           
                        ],
                        "body":{
                           "mode":"raw",
                           "raw":"{\n    \"status\": \"aprovado\"\n}",
                           "options":{
                              "raw":{
                                 "language":"json"
                              }
                           }
                        },
                        "url":{
                           "raw":"{{base_url}}/api/v1/travel-orders/:travel_order_id/status",
                           "host":[
                              "{{base_url}}"
                           ],
                           "path":[
                              "api",
                              "v1",
                              "travel-orders",
                              ":travel_order_id",
                              "status"
                           ],
                           "variable":[
                              {
                                 "key":"travel_order_id",
                                 "value":"TRV-X7KP9M2B"
                              }
                           ]
                        }
                     }
                  },
                  {
                     "name":"Cancelar Pedido",
                     "request":{
                        "method":"PATCH",
                        "header":[
                           
                        ],
                        "body":{
                           "mode":"raw",
                           "raw":"{\n    \"status\": \"cancelado\"\n}",
                           "options":{
                              "raw":{
                                 "language":"json"
                              }
                           }
                        },
                        "url":{
                           "raw":"{{base_url}}/api/v1/travel-orders/:travel_order_id/status",
                           "host":[
                              "{{base_url}}"
                           ],
                           "path":[
                              "api",
                              "v1",
                              "travel-orders",
                              ":travel_order_id",
                              "status"
                           ],
                           "variable":[
                              {
                                 "key":"travel_order_id",
                                 "value":"TRV-X7KP9M2B"
                              }
                           ]
                        }
                     }
                  },
                  {
                     "name":"Consultar Timeline de Auditoria",
                     "request":{
                        "method":"GET",
                        "header":[
                           
                        ],
                        "url":{
                           "raw":"{{base_url}}/api/v1/travel-orders/:travel_order_id/audits",
                           "host":[
                              "{{base_url}}"
                           ],
                           "path":[
                              "api",
                              "v1",
                              "travel-orders",
                              ":travel_order_id",
                              "audits"
                           ],
                           "variable":[
                              {
                                 "key":"travel_order_id",
                                 "value":"TRV-X7KP9M2B"
                              }
                           ]
                        }
                     }
                  }
               ]
            },
            {
               "name":"Listar Pedidos (Filtros Avançados)",
               "request":{
                  "method":"GET",
                  "header":[
                     
                  ],
                  "url":{
                     "raw":"{{base_url}}/api/v1/travel-orders?status=solicitado",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "travel-orders"
                     ],
                     "query":[
                        {
                           "key":"status",
                           "value":"solicitado"
                        }
                     ]
                  }
               }
            },
            {
               "name":"Criar Pedido",
               "request":{
                  "method":"POST",
                  "header":[
                     
                  ],
                  "body":{
                     "mode":"raw",
                     "raw":"{\n    \"origin\": \"Curitiba\",\n    \"destination\": \"Rio de Janeiro\",\n    \"departure_date\": \"2026-07-20\",\n    \"return_date\": \"2026-07-25\"\n}",
                     "options":{
                        "raw":{
                           "language":"json"
                        }
                     }
                  },
                  "url":{
                     "raw":"{{base_url}}/api/v1/travel-orders",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "travel-orders"
                     ]
                  }
               }
            },
            {
               "name":"Consultar Detalhes",
               "request":{
                  "method":"GET",
                  "header":[
                     
                  ],
                  "url":{
                     "raw":"{{base_url}}/api/v1/travel-orders/:travel_order_id",
                     "host":[
                        "{{base_url}}"
                     ],
                     "path":[
                        "api",
                        "v1",
                        "travel-orders",
                        ":travel_order_id"
                     ],
                     "variable":[
                        {
                           "key":"travel_order_id",
                           "value":"TRV-X7KP9M2B"
                        }
                     ]
                  }
               }
            }
         ],
         "auth":{
            "type":"bearer",
            "bearer":[
               {
                  "key":"token",
                  "value":"{{jwt_token}}",
                  "type":"string"
               }
            ]
         }
      }
   ],
   "variable":[
      {
         "key":"base_url",
         "value":"http://localhost"
      },
      {
         "key":"jwt_token",
         "value":""
      }
   ]
}